[node name="StrayCat" parent="NPCs" instance=ExtResource("12_npc")]
transform = Transform3D(0.7, 0, 0, 0, 0.55, 0, 0, 0, 0.7, -6, 0.05, 9)
id = "stray_cat"
character_name = "\u0411\u0440\u043E\u0434\u044F\u0447\u0438\u0439 \u043A\u043E\u0442"
character_type = 1
attitude = 1
short_phrase = "\u041C\u0440\u0440?"
dialogue = "\u0421\u0442\u0430\u0440\u044B\u0439 \u0443\u043B\u0438\u0447\u043D\u044B\u0439 \u043A\u043E\u0442 \u0437\u043D\u0430\u0435\u0442 \u0433\u043E\u0440\u043E\u0434 \u043B\u0443\u0447\u0448\u0435 \u043B\u044E\u0434\u0435\u0439. \u041A\u0430\u0436\u0435\u0442\u0441\u044F, \u043E\u043D \u0447\u0442\u043E-\u0442\u043E \u0432\u0438\u0434\u0435\u043B \u0443 \u043C\u0435\u0442\u0440\u043E."
description = "\u0421\u0442\u0430\u0440\u044B\u0439 \u0443\u043B\u0438\u0447\u043D\u044B\u0439 \u043A\u043E\u0442. \u041D\u0435 \u0441\u043F\u0435\u0448\u0438\u0442 \u0434\u043E\u0432\u0435\u0440\u044F\u0442\u044C, \u043D\u043E \u0441\u043B\u044B\u0448\u0438\u0442 \u043F\u043E\u0447\u0442\u0438 \u0432\u0441\u0435."
highlight_color = Color(0.9, 0.82, 0.55, 1)

[node name="OldWoman" parent="NPCs" instance=ExtResource("12_npc")]
transform = Transform3D(0.85, 0, 0, 0, 1.15, 0, 0, 0, 0.85, 9, 0.08, 4)
id = "old_woman"
character_name = "\u0422\u0438\u0445\u0430\u044F \u0436\u0435\u043D\u0449\u0438\u043D\u0430"
character_type = 0
attitude = 1
short_phrase = "\u0411\u0443\u0434\u044C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u0435\u043D."
dialogue = "\u041E\u043D\u0430 \u0441\u043C\u043E\u0442\u0440\u0438\u0442 \u043C\u0438\u043C\u043E \u043A\u043E\u0442\u0430, \u0431\u0443\u0434\u0442\u043E \u0432\u0438\u0434\u0438\u0442 \u043D\u0435 \u0443\u043B\u0438\u0446\u0443, \u0430 \u0442\u043E, \u0447\u0442\u043E \u0437\u0430 \u043D\u0435\u0439. \u041E\u043D\u0430 \u0441\u043B\u044B\u0448\u0430\u043B\u0430 \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0439 \u0441\u0432\u0435\u0442 \u0443 \u043C\u0435\u0442\u0440\u043E."
description = "\u0427\u0435\u043B\u043E\u0432\u0435\u043A \u0441 \u043E\u0447\u0435\u043D\u044C \u0443\u0441\u0442\u0430\u043B\u044B\u043C\u0438 \u0440\u0443\u043A\u0430\u043C\u0438. \u041D\u0435 \u0432\u0440\u0430\u0433, \u043D\u043E \u0434\u0435\u0440\u0436\u0438\u0442 \u0434\u0438\u0441\u0442\u0430\u043D\u0446\u0438\u044E."
highlight_color = Color(1, 0.8, 0.55, 1)

[node name="YardDog" parent="NPCs" instance=ExtResource("12_npc")]
transform = Transform3D(1.1, 0, 0, 0, 0.72, 0, 0, 0, 0.85, 16, 0.06, 15)
id = "yard_dog"
character_name = "\u0414\u0432\u043E\u0440\u043E\u0432\u044B\u0439 \u043F\u0435\u0441"
character_type = 2
attitude = 2
short_phrase = "\u0413\u0430\u0432!"
dialogue = "\u041F\u0435\u0441 \u043D\u0435 \u0434\u0430\u0435\u0442 \u043F\u043E\u0434\u043E\u0439\u0442\u0438 \u043A \u0432\u043E\u0440\u043E\u0442\u0430\u043C. \u0415\u0433\u043E \u0441\u0442\u0440\u0430\u0445 \u0433\u0440\u043E\u043C\u0447\u0435 \u0437\u043B\u043E\u0441\u0442\u0438."
description = "\u041D\u0430\u0441\u0442\u043E\u0440\u043E\u0436\u0435\u043D\u043D\u044B\u0439 \u043F\u0435\u0441 \u0443 \u0447\u0443\u0436\u043E\u0433\u043E \u0434\u0432\u043E\u0440\u0430."
can_be_purred = false
highlight_color = Color(1, 0.45, 0.36, 1)

[node name="RoofBird" parent="NPCs" instance=ExtResource("12_npc")]
transform = Transform3D(0.45, 0, 0, 0, 0.45, 0, 0, 0, 0.45, -14, 0.08, -7)
id = "roof_bird"
character_name = "\u041F\u0442\u0438\u0446\u0430 \u043D\u0430 \u043A\u0440\u044B\u0448\u0435"
character_type = 3
attitude = 1
short_phrase = "\u041A\u0430\u0440-\u0440-\u0440."
dialogue = "\u041F\u0442\u0438\u0446\u0430 \u0432\u0438\u0434\u0435\u043B\u0430 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u0442\u0430\u043C, \u0433\u0434\u0435 \u0443\u043B\u0438\u0446\u0430 \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u0442\u044C \u043F\u0443\u0441\u0442\u043E\u0439."
description = "\u0425\u0443\u0434\u0430\u044F \u043F\u0442\u0438\u0446\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u043C\u043D\u043E\u0433\u043E \u0432\u0438\u0434\u0438\u0442 \u0441\u0432\u0435\u0440\u0445\u0443."
can_be_purred = false
highlight_color = Color(0.7, 0.85, 1, 1)

[node name="PipeRat" parent="NPCs" instance=ExtResource("12_npc")]
transform = Transform3D(0.45, 0, 0, 0, 0.32, 0, 0, 0, 0.7, 2, 0.04, -10)
id = "pipe_rat"
character_name = "\u041A\u0440\u044B\u0441\u0430 \u0443 \u0442\u0440\u0443\u0431"
character_type = 4
attitude = 1
short_phrase = "\u041C\u043D\u0435 \u043D\u0435\u043A\u043E\u0433\u0434\u0430."
dialogue = "\u041A\u0440\u044B\u0441\u0430 \u043F\u0440\u044F\u0447\u0435\u0442 \u0433\u043B\u0430\u0437\u0430. \u041E\u043D\u0430 \u0437\u043D\u0430\u0435\u0442 \u043F\u043E\u0434\u0437\u0435\u043C\u043D\u044B\u0435 \u0445\u043E\u0434\u044B, \u043D\u043E \u043D\u0435 \u0432\u0435\u0440\u0438\u0442 \u043A\u043E\u0442\u0430\u043C."
description = "\u041C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439 \u0436\u0438\u0442\u0435\u043B\u044C \u0442\u0435\u043C\u043D\u044B\u0445 \u043C\u0435\u0441\u0442. \u041D\u0435 \u0434\u0440\u0443\u0433, \u043D\u043E \u0438 \u043D\u0435 \u0432\u0440\u0430\u0433."
can_be_purred = false
highlight_color = Color(0.62, 1, 0.74, 1)

